# Default — let Git decide, normalize on commit
* text=auto

# ── Source code (LF) ─────────────────────────────────────────────────────────
*.kt        text eol=lf
*.kts       text eol=lf
*.py        text eol=lf
*.xml       text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.properties text eol=lf
*.gradle    text eol=lf
*.pro       text eol=lf
*.md        text eol=lf
*.html      text eol=lf

# ── Data & config text files (LF) ────────────────────────────────────────────
*.csv       text eol=lf
*.txt       text eol=lf

# ── Shell scripts ─────────────────────────────────────────────────────────────
gradlew     text eol=lf
*.sh        text eol=lf
*.bat       text eol=crlf

# ── Jupyter notebooks (union merge to reduce conflicts) ───────────────────────
*.ipynb     text eol=lf merge=union

# ── ML model binaries ─────────────────────────────────────────────────────────
*.tflite        binary
*.onnx          binary
*.keras         binary
*.safetensors   binary
*.pt            binary
*.pkl           binary
*.h5            binary

# ── Android / Java binaries ───────────────────────────────────────────────────
*.apk   binary
*.aar   binary
*.jar   binary
*.class binary
*.dex   binary

# ── Images ────────────────────────────────────────────────────────────────────
*.webp  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   text eol=lf

# ── Archives & misc binaries ──────────────────────────────────────────────────
*.zip   binary
*.tar   binary
*.gz    binary
*.bin   binary
*.pdf   binary

# ── Gradle build cache (binary, don't diff) ───────────────────────────────────
*.lock  binary
