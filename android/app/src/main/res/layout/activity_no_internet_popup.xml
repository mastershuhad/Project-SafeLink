<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/no_internet_blue"
    android:layout_margin="24dp"
    android:elevation="8dp"
    android:padding="24dp">

    <!-- Icon + title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📡"
            android:textSize="28sp"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:text="@string/no_internet_title" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textSize="15sp"
        android:textColor="#CCFFFFFF"
        android:lineSpacingMultiplier="1.3"
        android:text="@string/no_internet_body1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="14sp"
        android:textColor="#AAFFFFFF"
        android:text="@string/no_internet_body2" />

    <!-- URL preview -->
    <TextView
        android:id="@+id/tvUrlPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textSize="11sp"
        android:textColor="#88FFFFFF"
        android:fontFamily="monospace"
        android:maxLines="1"
        android:ellipsize="middle" />

    <Button
        android:id="@+id/btnOk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/btn_ok"
        android:backgroundTint="@android:color/white"
        android:textColor="@color/no_internet_blue" />

</LinearLayout>
