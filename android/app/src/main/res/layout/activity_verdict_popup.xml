<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:layout_margin="24dp"
    android:elevation="8dp">

    <!-- Colored verdict banner stripe (10dp) -->
    <View
        android:id="@+id/bannerStripe"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:background="@color/warning_orange" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Verdict title -->
        <TextView
            android:id="@+id/tvVerdictTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:text="@string/verdict_warning" />

        <!-- Verdict subtitle -->
        <TextView
            android:id="@+id/tvVerdictSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="14sp"
            android:textColor="#555555"
            android:text="@string/verdict_warning_sub" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:background="#E0E0E0" />

        <!-- XAI Reason -->
        <TextView
            android:id="@+id/tvReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="17sp"
            android:textColor="@android:color/black"
            android:lineSpacingMultiplier="1.3" />

        <!-- Gemini explanation (WARNING only, hidden by default) -->
        <TextView
            android:id="@+id/tvGemini"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="15sp"
            android:textColor="#444444"
            android:textStyle="italic"
            android:visibility="gone" />

        <!-- URL preview -->
        <TextView
            android:id="@+id/tvUrlPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textSize="11sp"
            android:textColor="#888888"
            android:fontFamily="monospace"
            android:maxLines="2"
            android:ellipsize="middle" />

        <!-- Confidence badge -->
        <TextView
            android:id="@+id/tvConfidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="#555555" />

        <!-- Button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnOpenAnyway"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:text="@string/btn_open_anyway"
                android:textColor="@color/warning_orange" />

            <Button
                android:id="@+id/btnBlock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/btn_go_back"
                android:backgroundTint="@color/danger_red" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
