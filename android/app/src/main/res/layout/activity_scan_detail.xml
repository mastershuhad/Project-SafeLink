<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- URL -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#888888" android:text="@string/label_url" />
        <TextView android:id="@+id/tvDetailUrl"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="@android:color/black"
            android:fontFamily="monospace" android:layout_marginBottom="12dp" />

        <!-- Verdict -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#888888" android:text="@string/label_verdict" />
        <TextView android:id="@+id/tvDetailVerdict"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />

        <!-- Confidence -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#888888" android:text="@string/label_confidence" />
        <TextView android:id="@+id/tvDetailConfidence"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="16sp" android:textColor="@android:color/black" android:layout_marginBottom="12dp" />

        <!-- Reason -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#888888" android:text="@string/label_reason" />
        <TextView android:id="@+id/tvDetailReason"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="15sp" android:textColor="@android:color/black"
            android:lineSpacingMultiplier="1.3" android:layout_marginBottom="12dp" />

        <!-- Gemini (hidden by default) -->
        <TextView android:id="@+id/labelGemini"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#888888"
            android:text="@string/label_gemini" android:visibility="gone" />
        <TextView android:id="@+id/tvDetailGemini"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="#444444" android:textStyle="italic"
            android:layout_marginBottom="12dp" android:visibility="gone" />

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#E0E0E0" android:layout_marginBottom="12dp" />

        <!-- Technical scores -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="13sp" android:textStyle="bold" android:textColor="@android:color/black"
            android:text="@string/label_scores" android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#888888" android:text="@string/label_cnn" />
                <TextView android:id="@+id/tvDetailCnnScore"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="16sp" android:textColor="@android:color/black" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#888888" android:text="@string/label_bert" />
                <TextView android:id="@+id/tvDetailBertScore"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="16sp" android:textColor="@android:color/black" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="8dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#888888" android:text="@string/label_anomaly" />
                <TextView android:id="@+id/tvDetailAnomalyMse"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="16sp" android:textColor="@android:color/black" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textColor="#888888" android:text="@string/label_domain_age" />
                <TextView android:id="@+id/tvDetailDomainAge"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="16sp" android:textColor="@android:color/black" />
            </LinearLayout>
        </LinearLayout>

        <!-- Layer + timestamp -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#888888"
            android:text="@string/label_layer" android:layout_marginTop="8dp" />
        <TextView android:id="@+id/tvDetailLayer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="@android:color/black" android:fontFamily="monospace" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="11sp" android:textColor="#888888"
            android:text="@string/label_timestamp" android:layout_marginTop="8dp" />
        <TextView android:id="@+id/tvDetailTimestamp"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textSize="14sp" android:textColor="@android:color/black" />

    </LinearLayout>
</ScrollView>
